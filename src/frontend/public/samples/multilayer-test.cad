$HEADER
GENCAD 1.4
UNITS USER 1000
$ENDHEADER
$BOARD
$ENDBOARD
$SHAPES
SHAPE SH1
PIN 1 PAD1 0 0 TOP 0 0
PIN 2 PAD1 100 0 TOP 0 0
$ENDSHAPES
$DEVICES
$ENDDEVICES
$COMPONENTS
COMPONENT U1
PLACE 200 200
LAYER TOP
SHAPE SH1 0 0
DEVICE DEV1
$ENDCOMPONENTS
$SIGNALS
SIGNAL NET_A
NODE U1 1
NODE U1 2
$ENDSIGNALS
$TRACKS
TRACK T1 8
$ENDTRACKS
$ROUTES
ROUTE NET_A
LAYER TOP
TRACK T1
LINE 100 100 400 100
LAYER INNER1
LINE 400 100 400 400
LAYER BOTTOM
LINE 400 400 100 400
$ENDROUTES
