# Samples — ignored by default. The public repo does NOT ship real-world
# boardview files or schematic PDFs (not redistributable). Local working tree
# may have whatever you bring. To re-introduce a redistributable test fixture,
# whitelist it explicitly here.
samples/*

# Claude — local settings stay out of the public repo
.claude/settings.json
.claude/worktrees/
.worktrees/

# Internal AI-assisted-development working notes — not for public consumption
docs/superpowers/
docs/agents/
docs/analysis/

# SQLite WAL / shared-memory transient files (created when DB is open)
*.db-shm
*.db-wal

# Test results (root level)
test-results/

# Deploy credentials
deploy.conf
*.tar.gz

# Local release artifacts (use GitHub Releases for distribution)
release-artifacts/

# Release pipeline staging — generated by scripts/release.sh
out/

# Claude scheduled-tasks lockfile
.claude/scheduled_tasks.lock

# Transient import-review staging files; never committed
import-staging/
**/__pycache__/
.tavily-env
.superpowers/
